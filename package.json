{
    "name": "trifolium-frontend",
    "private": true,
    "type": "module",
    "description": "Trifolium — professional compounding-pharmacy platform. Vue 3 + Inertia.js frontend for a Laravel backend (Hebrew, RTL).",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite --config vite.preview.config.js",
        "build:preview": "vite build --config vite.preview.config.js",
        "build:demo": "vite build --config vite.preview.config.js --mode static && node scripts/build-static-demo.mjs",
        "format": "prettier --write resources/ preview/ scripts/",
        "format:check": "prettier --check resources/ preview/ scripts/",
        "lint": "eslint . --fix",
        "lint:check": "eslint ."
    },
    "dependencies": {
        "@inertiajs/vue3": "^2.0.0",
        "vue": "^3.5.13"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.2",
        "@vitejs/plugin-vue": "^5.2.1",
        "laravel-vite-plugin": "^1.2.0",
        "tailwindcss": "^4.3.2",
        "vite": "^6.0.11",
        "@eslint/js": "^9.19.0",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@vue/eslint-config-typescript": "^14.3.0",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-vue": "^9.32.0",
        "prettier": "^3.4.2",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "typescript": "^5.2.2",
        "typescript-eslint": "^8.23.0"
    }
}
